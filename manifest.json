{
  "manifest_version": 3,
  "name": "InvoiceFlow for Nextcloud",
  "version": "0.3.0",
  "description": "Lädt Rechnungen von Amazon, eBay, Zalando & Co automatisch via WebDAV in einen Nextcloud-Ordner (z.B. Paperless consume-Verzeichnis).",

  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "activeTab",
    "offscreen"
  ],

  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],

  "host_permissions": [
    "*://*.amazon.de/*",
    "*://*.amazon.com/*",
    "*://*.amazon.co.uk/*",
    "*://*.amazon.fr/*",
    "*://*.amazon.it/*",
    "*://*.amazon.es/*",
    "*://*.ebay.de/*",
    "*://*.zalando.de/*",
    "*://*.mediamarkt.de/*",
    "*://*.otto.de/*",
    "*://*.aliexpress.com/*",
    "*://pay.openai.com/*",
    "*://platform.openai.com/*",
    "*://invoicedata.stripe.com/*",
    "*://github.com/*",
    "*://ads.google.com/*",
    "*://payments.google.com/*",
    "*://www.linkedin.com/*",
    "*://business.facebook.com/*",
    "*://admin.microsoft.com/*",
    "*://admin.cloud.microsoft/*",
    "*://www.paypal.com/*",
    "*://business.revolut.com/*"
  ],

  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_page": "options.html",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.de/*",
        "*://*.amazon.com/*",
        "*://*.amazon.co.uk/*",
        "*://*.amazon.fr/*",
        "*://*.amazon.it/*",
        "*://*.amazon.es/*"
      ],
      "js": ["src/content.js", "src/plugins/amazon.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.ebay.de/*"],
      "js": ["src/content.js", "src/plugins/ebay.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.zalando.de/*"],
      "js": ["src/content.js", "src/plugins/zalando.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.mediamarkt.de/*"],
      "js": ["src/content.js", "src/plugins/mediamarkt.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.otto.de/*"],
      "js": ["src/content.js", "src/plugins/otto.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.aliexpress.com/*"],
      "js": ["src/content.js", "src/plugins/aliexpress.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://pay.openai.com/*"],
      "js": ["src/content.js", "src/plugins/chatgpt.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://github.com/*"],
      "js": ["src/content.js", "src/plugins/github.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://ads.google.com/*"],
      "js": ["src/content.js", "src/plugins/googleads.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://payments.google.com/*"],
      "js": ["src/content.js", "src/plugins/googlepay.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.linkedin.com/*"],
      "js": ["src/content.js", "src/plugins/linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://business.facebook.com/*"],
      "js": ["src/content.js", "src/plugins/metaads.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://admin.microsoft.com/*"],
      "js": ["src/content.js", "src/plugins/microsoft365.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://platform.openai.com/*"],
      "js": ["src/content.js", "src/plugins/openaiapi.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.paypal.com/*"],
      "js": ["src/content.js", "src/plugins/paypal.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://business.revolut.com/*"],
      "js": ["src/content.js", "src/plugins/revolut.js"],
      "run_at": "document_idle"
    }
  ]
}
